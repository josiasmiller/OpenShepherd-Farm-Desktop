#!/usr/bin/env bash
set -euo pipefail

# Regex for semantic versioning (major.minor.patch with optional pre-release/build)
SEMVER_REGEX='^[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z.-]+)?(\+[0-9A-Za-z.-]+)?$'

# Writing into version files one level up from this script location
SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
TARGET_DIR="$SCRIPT_DIR/.."

farm=""
registry=""
single=""

usage() {
  cat <<EOF
Usage:
  $0 <semver>                  # Write semver to both version.farm and version.registry
  $0 --farm <semver>           # Write semver to version.farm
  $0 --registry <semver>       # Write semver to version.registry
  $0 --farm <semver> --registry <semver>
                               # Write each semver to respective file

Arguments:
  <semver>   Semantic version string (e.g. 1.2.3, 1.2.3-alpha, 1.2.3+build)
EOF
}

# No arguments → usage
if [[ $# -eq 0 ]]; then
  usage
  exit 0
fi

# Parse arguments
if [[ $# -eq 1 ]]; then
  single="$1"
elif [[ $# -ge 2 ]]; then
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --farm)
        farm="$2"
        shift 2
        ;;
      --registry)
        registry="$2"
        shift 2
        ;;
      *)
        echo "Error: Unknown argument '$1'"
        usage
        exit 1
        ;;
    esac
  done
fi

# Validate and write
validate_and_write() {
  local version="$1"
  local file="$2"

  if [[ ! "$version" =~ $SEMVER_REGEX ]]; then
    echo "Error: '$version' is not a valid semantic version string"
    exit 1
  fi

  echo "$version" > "$TARGET_DIR/$file"
  echo "Wrote $version to $file"
}

if [[ -n "$single" ]]; then
  if [[ ! "$single" =~ $SEMVER_REGEX ]]; then
    echo "Error: '$single' is not a valid semantic version string"
    exit 1
  fi
  echo "$single" > "$TARGET_DIR/version.farm"
  echo "$single" > "$TARGET_DIR/version.registry"
  echo "Wrote $single to version.farm and version.registry"
else
  if [[ -n "$farm" ]]; then
    validate_and_write "$farm" version.farm
  fi
  if [[ -n "$registry" ]]; then
    validate_and_write "$registry" version.registry
  fi
fi
