{
  "files": [],
  "compilerOptions": {
    "composite": true,
    "target": "ESNext",
    "jsx": "react-jsx",
    "allowJs": true,
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": false,
    "sourceMap": true,
    "resolveJsonModule": true,
    "noEmitOnError": true,
    "baseUrl": ".",
    "paths": {
      "*": ["node_modules/*"],
      "@app/*": ["src/packages/app/*"],
      "@database/async": ["src/packages/database"],
      "@ipc/api/*": ["src/packages/ipc/api/src/*.ts"],
      "@ipc/preload/*": ["src/packages/ipc/preload/src/*.ts"],
      "@common/*": ["src/packages/common/*"]
    }
  },
}
