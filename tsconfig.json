{
  "files": [],
  "compilerOptions": {
    "composite": true,
    "target": "ESNext",
    "jsx": "react-jsx",
    "allowJs": true,
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": false,
    "sourceMap": true,
    "resolveJsonModule": true,
    "noEmitOnError": true,
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/packages/app/*"],
      "@database/async": ["src/packages/database"],
      "@database/schema": ["src/packages/database/src/schema"],
      "@ipc/api": ["src/packages/ipc/api"],
      "@ipc/core": ["src/packages/ipc/core"],
      "@ipc/api/*": ["src/packages/ipc/api/src/*.ts"],
      "@ipc/preload/*": ["src/packages/ipc/preload/src/*.ts"],
      "@common/*": ["src/packages/common/*"],
      "@main/*": ["src/main/*"]
    }
  }
}
