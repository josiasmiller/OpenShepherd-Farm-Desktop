{
  "compilerOptions": {
    "jsx": "react",
    "target": "ESNext",
    "module": "ESNext",
    "outDir": "dist",
    "rootDir": "./src",               // ✅ This line tells TypeScript that "src" is the base
    "strict": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src", "vite.config.ts", "src/types/jest.d.ts", "src/types/types.d.ts"],
  "exclude": ["dist"]
}
