{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "node",
    "rootDir": ".",
    "outDir": "build"
  },
  "include": ["./**/*.ts", "./**/*.tsx"],
  "exclude": ["./build/*", "./**/jest.*" ,"./**/*.test.ts", "./**/*.test.tsx"],
  "references": [
    { "path": "../packages/app/buildVariant" },
    { "path": "../packages/app/api" },
    { "path": "../packages/common/core" },
    { "path": "../packages/common/time" },
    { "path": "../packages/ipc/api" }
  ]
}
