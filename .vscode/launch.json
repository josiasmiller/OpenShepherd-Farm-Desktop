{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Main - Farm",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "${workspaceFolder}/node_modules/@electron-forge/cli/script/vscode.sh",
      "windows": {
        "runtimeExecutable": "${workspaceFolder}/node_modules/@electron-forge/cli/script/vscode.cmd"
      },
      "env": {
        "NODE_ENV": "development",
        "APP_VARIANT": "farm"
      },
      "args": ["-- --inspect-brk-electron"],
      "console": "integratedTerminal"
    },
    {
      "name": "Debug Main - Registry",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "${workspaceFolder}/node_modules/@electron-forge/cli/script/vscode.sh",
      "windows": {
        "runtimeExecutable": "${workspaceFolder}/node_modules/@electron-forge/cli/script/vscode.cmd"
      },
      "env": {
        "NODE_ENV": "development",
        "APP_VARIANT": "registry"
      },
      "args": ["-- --inspect-brk-electron"],
      "console": "integratedTerminal"
    }
  ]
}
