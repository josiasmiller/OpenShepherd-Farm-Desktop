{
  "type": "commonjs",
  "main": ".webpack/main",
  "version": "0.0.1",
  "author": "AnimalTrakker",
  "scripts": {
    "package": "npm run package:farm && npm run package:registry",
    "package:farm": "cross-env APP_VARIANT=farm electron-forge package",
    "package:registry": "cross-env APP_VARIANT=registry electron-forge package",
    "start:farm": "cross-env APP_VARIANT=farm NODE_ENV=development electron-forge start",
    "start:registry": "cross-env APP_VARIANT=registry NODE_ENV=development electron-forge start",
    "make": "npm run make:farm && npm run make:registry",
    "make:farm": "cross-env APP_VARIANT=farm electron-forge make",
    "make:registry": "cross-env APP_VARIANT=registry electron-forge make"
  },
