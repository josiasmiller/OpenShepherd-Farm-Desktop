{
  "name": "animaltrakker_farm_desktop",
  "version": "1.0.0",
  "type": "module",
  "author": "AnimalTrakker",
  "description": "AnimalTrakker Farm Desktop App",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc && vite build --config src/vite.config.ts && node scripts/copyAssets.js",
    "build:standard": "cross-env APP_VERSION_TYPE=standard npm run build",
    "build:registry": "cross-env APP_VERSION_TYPE=registry npm run build",
    "start": "electron-forge start",
    "vite": "vite --config src/vite.config.ts",
    "test": "jest",
    "package": "electron-forge package",
    "make": "npm run build && electron-forge make",
    "make:standard": "cross-env APP_VERSION_TYPE=standard npm run build && electron-forge make",
    "make:registry": "cross-env APP_VERSION_TYPE=registry npm run build && electron-forge make"
  },
  "keywords": [],
