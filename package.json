{
  "name": "animaltrakker_farm_desktop",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc",
    "start": "tsc && electron .",
    "dev": "tsc && electron . --no-sandbox",
    "test": "echo \"Error: no test specified\" && exit 1",
    "copy-assets": "npm run copy-assets-$(npm_config_platform)",
    "copy-assets-linux": "cp -r src/renderer/pages dist/renderer/pages",
    "copy-assets-mac": "cp -r src/renderer/pages dist/renderer/pages",
    "copy-assets-windows": "xcopy /E /I /H src\\renderer\\pages\\ dist\\renderer\\pages\\",
    "start_windows": "npm run copy-assets-windows && npm start",
    "start_mac": "npm run copy-assets-mac && npm start",
    "start_linux": "npm run copy-assets-linux && npm start"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/electron": "^1.6.12",
    "@types/node": "^22.13.1",
    "cross-env": "^7.0.3",
    "electron": "^34.1.1",
    "electron-builder": "^25.1.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
